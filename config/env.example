# Cloud API Keys (only needed for escalation — local works without these)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Local LLM config
OLLAMA_MODEL=gpt-oss:20b
# Examples: gemma4:31b, qwen3:30b
OLLAMA_HOST=http://localhost:11434

# STT config
WHISPER_MODEL=base.en
# Options: tiny.en, base.en, small.en, medium.en, large-v3

# TTS config
TTS_ENGINE=auto
# Options: auto (prefer Piper, fall back to say), piper, say
PIPER_VOICE=en_US-lessac-medium
PIPER_SENTENCE_PAUSE_MS=180
PIPER_LINE_PAUSE_MS=320
# Optional: PIPER_DOWNLOAD_DIR=/absolute/path/to/piper-voices
HEADTTS_VOICE=af_bella
HEADTTS_LANGUAGE=en-us
# Use "null" to disable the HeadTTS pronunciation dictionary
HEADTTS_DICTIONARY_URL=https://cdn.jsdelivr.net/npm/@met4citizen/headtts@1.2/dictionaries/
# Options: auto (prefer server phonemes when available), speech, phonetic
HEADTTS_INPUT_MODE=auto
HEADTTS_PHONEMIZER_LANGUAGE=en-us
HEADTTS_PHONEMIZER_USE_ESPEAK=true
HEADTTS_PHONEMIZER_USE_TRANSFORMER=false
# TalkingHead avatar presets: julia, mpfb, brunette, brunette-t, avaturn, avatar, avatarsdk
TALKING_HEAD_CHARACTER=julia
# Optional: override preset with a custom GLB URL
# TALKING_HEAD_AVATAR_URL=https://example.com/my-avatar.glb
TALKING_HEAD_BODY=F

SPEECH_NORMALIZER=auto
# Options: auto (use NeMo if installed), nemo (force NeMo), none
SPEECH_NORMALIZER_INPUT_CASE=cased
SPEECH_NORMALIZER_LANG=en
SPEECH_NORMALIZER_EXPAND_COMPACT_UNITS=true

# Media search cache
IMAGE_CACHE_TTL_SECONDS=3600
SOUND_CACHE_TTL_SECONDS=3600
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
FREESOUND_API_KEY=
# Optional for future OAuth-style integrations
FREESOUND_CLIENT_ID=
FREESOUND_CLIENT_SECRET=

# Safety
SAFESEARCH=strict
