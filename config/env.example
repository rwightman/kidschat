# Cloud API Keys (only needed for escalation — local works without these)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Local LLM config
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_HOST=http://localhost:11434

# STT config
WHISPER_MODEL=base.en
# Options: tiny.en, base.en, small.en, medium.en, large-v3

# TTS config
TTS_ENGINE=auto
# Options: auto (prefer Piper, fall back to say), piper, say
PIPER_VOICE=en_US-lessac-medium
PIPER_SENTENCE_PAUSE_MS=180
PIPER_LINE_PAUSE_MS=320
# Optional: PIPER_DOWNLOAD_DIR=/absolute/path/to/piper-voices

# Media search cache
IMAGE_CACHE_TTL_SECONDS=3600
SOUND_CACHE_TTL_SECONDS=3600

# Safety
SAFESEARCH=strict
